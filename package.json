{
  "name": "valkenhall",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.6",
  "scripts": {
    "icons:generate": "bun scripts/app-icons.js",
    "dev": "bun run desktop:dev",
    "dev:web": "bun run update-cards && bun run clean && bun run dev:renderer",
    "dev:renderer": "bun --port 5173 --hot index.html --console",
    "desktop:dev": "bun run build:renderer && concurrently -k \"bun run desktop:renderer:dev\" \"bun run desktop:dev:app\"",
    "desktop:renderer:dev": "concurrently -k \"bun --watch scripts/build-web.js\" \"bun run preview\"",
    "desktop:dev:app": "ELECTROBUN_RENDERER_URL=http://127.0.0.1:4173 bun scripts/desktop-dev.js",
    "desktop:build": "bun run build && electrobun build",
    "update-cards": "bash ./update_cards.sh",
    "update-sorcery-cards": "bash ./update_sorcery_cards.sh",
    "download-sorcery-images": "bun scripts/download-sorcery-images.js",
    "build": "bun run icons:generate && bun run update-cards && bun run update-sorcery-cards && bun run clean && bun run build:renderer",
    "build:renderer": "bun scripts/build-web.js",
    "preview": "bun scripts/preview-web.js",
    "build:preview": "bun run build && bun run preview",
    "clean": "rm -rf dist",
    "test": "bun test",
    "test:watch": "bun --watch test"
  },
  "dependencies": {
    "@aws-crypto/sha256-js": "^5.2.0",
    "@aws-sdk/client-cognito-identity": "^3.956.0",
    "@aws-sdk/credential-providers": "^3.956.0",
    "@aws-sdk/signature-v4": "^3.370.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@radix-ui/react-dialog": "^1.1.15",
    "@smithy/protocol-http": "^5.3.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "electrobun": "^1.16.0",
    "express": "^4.21.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "multer": "^2.0.2",
    "pdf-lib": "^1.17.1",
    "preact": "^10.26.5",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.0",
    "shadcn": "^4.0.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "three": "^0.183.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.0.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "bun-plugin-tailwind": "^0.1.2",
    "concurrently": "^9.1.2"
  }
}
